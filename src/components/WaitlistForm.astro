---
interface Props {
  variant?: 'hero' | 'page' | 'on-green';
}

const { variant = 'page' } = Astro.props;

const buttonClass = variant === 'on-green'
  ? 'px-6 py-3 bg-white text-green font-semibold rounded-lg hover:bg-gray-100 transition-colors'
  : 'px-6 py-3 bg-[#2D8B57] text-white font-semibold rounded-lg hover:bg-[#25744A] transition-colors';

const helperClass = variant === 'page'
  ? 'text-sm mt-2 opacity-70 text-text'
  : 'text-sm mt-2 opacity-70 text-white';
---
<form name="waitlist" method="POST" data-netlify="true" netlify-honeypot="bot-field">
  <input type="hidden" name="form-name" value="waitlist" />
  <p class="hidden"><label>Don't fill this out: <input name="bot-field" /></label></p>
  <div class="flex flex-col sm:flex-row gap-3">
    <input
      type="email"
      name="email"
      placeholder="your@email.com"
      required
      class="flex-1 px-4 py-3 rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-[#2D8B57]"
    />
    <button
      type="submit"
      class={buttonClass}
    >
      Join Waitlist
    </button>
  </div>
  <p class={helperClass}>No spam. Unsubscribe anytime.</p>
</form>
