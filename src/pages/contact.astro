---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact"
  description="Get in touch with the ShieldEyes team."
>

  <section class="bg-section-bg py-20 px-4">
    <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-16">

        {/* Left column: contact info */}
        <div>
          <h1 class="text-3xl sm:text-4xl font-bold text-text mb-6">Get in Touch</h1>
          <p class="text-gray-600 text-lg leading-relaxed mb-8">
            We're happy to answer questions about ShieldEyes, discuss your project, or schedule a call.
          </p>

          <div class="space-y-5">
            <div>
              <p class="text-sm font-semibold text-text uppercase tracking-widest mb-1">Email</p>
              <a
                href="mailto:hello@shieldeyes.co"
                class="text-green font-medium hover:opacity-80 transition-opacity"
              >
                hello@shieldeyes.co
              </a>
            </div>

            <div>
              <p class="text-sm font-semibold text-text uppercase tracking-widest mb-1">Book a Call</p>
              <a
                href="#"
                class="text-green font-medium hover:opacity-80 transition-opacity"
              >
                Book a 20-minute call &rarr;
              </a>
            </div>

            <div>
              <p class="text-sm font-semibold text-text uppercase tracking-widest mb-1">Location</p>
              <p class="text-gray-600">Based in Oshawa, Ontario, Canada.</p>
            </div>
          </div>
        </div>

        {/* Right column: contact form */}
        <div class="bg-white rounded-xl shadow-sm p-8 sm:p-10">
          <h2 class="text-xl font-semibold text-text mb-6">Send us a message</h2>
          <form name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field">
            <input type="hidden" name="form-name" value="contact" />
            <p class="hidden"><label>Don't fill: <input name="bot-field" /></label></p>

            <div class="space-y-5">

              <label class="block">
                <span class="block text-sm font-semibold text-text mb-1.5">Name <span class="text-red-500">*</span></span>
                <input
                  type="text"
                  name="name"
                  required
                  class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-[#2D8B57] text-text"
                  placeholder="Your name"
                />
              </label>

              <label class="block">
                <span class="block text-sm font-semibold text-text mb-1.5">Email <span class="text-red-500">*</span></span>
                <input
                  type="email"
                  name="email"
                  required
                  class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-[#2D8B57] text-text"
                  placeholder="your@email.com"
                />
              </label>

              <label class="block">
                <span class="block text-sm font-semibold text-text mb-1.5">Message <span class="text-red-500">*</span></span>
                <textarea
                  name="message"
                  rows="5"
                  required
                  class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-[#2D8B57] text-text resize-y"
                  placeholder="How can we help?"
                ></textarea>
              </label>

              <button
                type="submit"
                class="w-full px-6 py-4 bg-[#2D8B57] text-white font-semibold rounded-lg hover:bg-[#25744A] transition-colors text-base"
              >
                Send Message
              </button>

            </div>
          </form>
        </div>

      </div>
    </div>
  </section>

</Layout>
